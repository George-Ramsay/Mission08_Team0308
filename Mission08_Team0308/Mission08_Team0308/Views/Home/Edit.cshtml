@model Mission08_Team0308.Models.TaskViewModel

@{
    ViewData["Title"] = "Edit Task";
}

<h2 class="mb-4">Edit Task</h2>

<form asp-action="Edit" method="post" class="row g-3">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="TaskItem.TaskItemId" />

    <div class="col-12">
        <label asp-for="TaskItem.Task" class="form-label"></label>
        <input asp-for="TaskItem.Task" class="form-control" />
        <span asp-validation-for="TaskItem.Task" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="TaskItem.DueDate" class="form-label"></label>
        <input asp-for="TaskItem.DueDate" type="date" class="form-control" />
        <span asp-validation-for="TaskItem.DueDate" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="TaskItem.Quadrant" class="form-label"></label>
        <select asp-for="TaskItem.Quadrant" class="form-select">
            <option value="">-- Select Quadrant --</option>
            <option value="1">Quadrant I</option>
            <option value="2">Quadrant II</option>
            <option value="3">Quadrant III</option>
            <option value="4">Quadrant IV</option>
        </select>
        <span asp-validation-for="TaskItem.Quadrant" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="TaskItem.CategoryId" class="form-label">Category</label>
        <select asp-for="TaskItem.CategoryId" class="form-select">
            <option value="">-- Select Category --</option>
            @foreach (var c in Model.Categories)
            {
                <option value="@c.CategoryId">@c.CategoryName</option>
            }
        </select>
        <span asp-validation-for="TaskItem.CategoryId" class="text-danger"></span>
    </div>

    <div class="col-md-6 d-flex align-items-end">
        <div class="form-check">
            <input class="form-check-input" asp-for="TaskItem.Completed" />
            <label class="form-check-label" asp-for="TaskItem.Completed">Completed</label>
        </div>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Quadrants" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}